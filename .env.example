# ─── DATABASE ──────────────────────────────────────────────────────────────────
DB_NAME=nutriapp
DB_USER=nutriapp
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD_32CHARS
DATABASE_URL=postgresql://nutriapp:CHANGE_ME_STRONG_PASSWORD_32CHARS@localhost:5432/nutriapp

# ─── REDIS ─────────────────────────────────────────────────────────────────────
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD
REDIS_URL=redis://:CHANGE_ME_REDIS_PASSWORD@localhost:6379

# ─── JWT ───────────────────────────────────────────────────────────────────────
# Gere com: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=CHANGE_ME_ACCESS_SECRET_64BYTES_HEX
JWT_REFRESH_SECRET=CHANGE_ME_REFRESH_SECRET_64BYTES_HEX
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# ─── CRIPTOGRAFIA (AES-256) ────────────────────────────────────────────────────
# Gere com: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=CHANGE_ME_32BYTE_HEX_KEY_FOR_AES256

# ─── API OPENAI (IA) ───────────────────────────────────────────────────────────
# Nunca exposta no frontend — apenas no backend
OPENAI_API_KEY=sk-CHANGE_ME
OPENAI_MODEL=gpt-5.4-mini

# ─── CORS ──────────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000,https://seudominio.com.br

# ─── APP ───────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
LOG_LEVEL=info
ENABLE_DEMO_AUTH=false
SECURITY_EMAIL=security@seudominio.com.br
PUBLIC_SECURITY_POLICY_URL=https://seudominio.com.br/security

# ─── LGPD ──────────────────────────────────────────────────────────────────────
DPO_EMAIL=dpo@seudominio.com.br
DATA_RETENTION_MONTHS=24
AUDIT_LOG_RETENTION_MONTHS=12

# ─── NEXT.JS WEB ───────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXTAUTH_SECRET=CHANGE_ME_NEXTAUTH_SECRET
NEXTAUTH_URL=http://localhost:3000

# ─── RATE LIMITING ─────────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
AUTH_RATE_LIMIT_MAX=5
